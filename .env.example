PORT=3000
SMS_PROVIDER=dev

# Appwrite Cloud Auth + profile persistence
APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
APPWRITE_PROJECT_ID=your-project-id
APPWRITE_API_KEY=your-server-api-key
APPWRITE_DATABASE_ID=tt-campus
APPWRITE_PROFILES_TABLE_ID=profiles

# Appwrite profiles table columns:
# user_id: string, size 36, required
# email: string, size 255, required
# name: string, size 128
# student_id: string, size 64
# auth_method: string, size 32
# created_at: string, size 64
# updated_at: string, size 64

# Twilio real SMS mode
# SMS_PROVIDER=twilio
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_FROM=+12345678900

# WeChat Pay v3 H5 payment
# WECHAT_PAY_MCH_ID=1900000001
# WECHAT_PAY_APP_ID=wxxxxxxxxxxxxxxxxx
# WECHAT_PAY_SERIAL_NO=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# WECHAT_PAY_PRIVATE_KEY_PATH=/absolute/path/to/apiclient_key.pem
# Or put the PEM string here with \n line breaks:
# WECHAT_PAY_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----
# WECHAT_PAY_NOTIFY_URL=https://your-domain.example.com/api/payments/wechat/notify

# Alipay WAP payment
# ALIPAY_APP_ID=2021000000000000
# ALIPAY_PRIVATE_KEY_PATH=/absolute/path/to/alipay_private_key.pem
# Or put the PEM string here with \n line breaks:
# ALIPAY_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----
# ALIPAY_NOTIFY_URL=https://your-domain.example.com/api/payments/alipay/notify
# ALIPAY_GATEWAY=https://openapi.alipay.com/gateway.do
